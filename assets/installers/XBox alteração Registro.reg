Windows Registry Editor Version 5.00

; Desativar painel inicial da Xbox Game Bar
[HKEY_CURRENT_USER\Software\Microsoft\GameBar]
"ShowStartupPanel"=dword:00000000

; Desativar captura GameDVR
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\GameDVR]
"AppCaptureEnabled"=dword:00000000

; Desativar GameDVR global
[HKEY_CURRENT_USER\System\GameConfigStore]
"GameDVR_Enabled"=dword:00000000

; Remover protocolo que chama o ms-gamingoverlay
[-HKEY_CLASSES_ROOT\ms-gamingoverlay]